# ── Neon.tech PostgreSQL ─────────────────────────────
# Copy your connection string from the Neon dashboard:
# Project → Connection Details → Connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── JWT ──────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ── Admin ────────────────────────────────────────────
# First admin account — created automatically on first run
ADMIN_EMAIL=admin@vtos.local
ADMIN_PASSWORD=ChangeMe123!

# ── Server ───────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS — comma-separated list of allowed origins ───
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500
